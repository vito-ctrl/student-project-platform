model PortfolioExport {
  id              String @id @default(cuid())

  userId          String
  projectId       String

  slug            String @unique

  generatedPdfUrl String?

  snapshotData    Json

  user            User    @relation(fields: [userId], references: [id])
  project         Project @relation(fields: [projectId], references: [id])

  createdAt       DateTime @default(now())
}